class Person:
    def __init__(self, name):
        self.name = name

    def show(self):
        print("Name:", self.name)

class Student(Person):
    def __init__(self, name, roll):
        super().__init__(name)
        self.roll = roll

    def show_details(self):
        print("Name:", self.name)
        print("Roll No:", self.roll)

s = Student("Sriram", 101)
s.show_details()
